# Secrets & credentials — never commit real keys, tokens, or signing material
.env
.env.*
!.env.example
!.env.sample
*.pem
*.p12
*.pfx
*.key
*.cer
*.mobileprovision
*.provisionprofile
**/key.properties
# Firebase / Google client configs often include API keys; omit these lines if you intentionally commit them.
**/google-services.json
**/GoogleService-Info.plist
**/serviceAccount*.json
**/*credentials*.json
secrets.json
secrets.yaml
.secrets/
signing/
id_rsa
id_ed25519
id_ecdsa
*.kdbx

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
.cursor/
